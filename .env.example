# Authentication
# Generate with: node -e "const b=require('bcryptjs');b.hash('yourpassword',12).then(console.log)"
FRANCESCA_PASSWORD_HASH=

# JWT secret — generate with: openssl rand -base64 32
JWT_SECRET=

# Plaid (use Plaid Sandbox for development)
PLAID_CLIENT_ID=
PLAID_SECRET=
PLAID_ENV=sandbox

# Plaid token encryption key — generate with: openssl rand -hex 32
PLAID_TOKEN_ENCRYPTION_KEY=

# Anthropic
ANTHROPIC_API_KEY=

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
